{
  "name": "myfirstbot-v3",
  "version": "0.1.1",
  "description": "My first bot v3",
  "main": "index.ts",
  "scripts": {
    "build": "npx tsc",
    "start": "npx tsc && node dist/index.js",
    "dev": "rm -rf ./dist && npx tsc && node dist/index.js",
    "test": "mocha --recursive --extension spec.ts --require ts-node/register",
    "nyc": "nyc mocha --recursive --extension spec.ts --require ts-node/register && nyc report --reporter=lcov"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VadimCpp/myfirstbot-v3"
  },
