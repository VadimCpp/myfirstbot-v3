  "bugs": {
    "url": "https://github.com/VadimCpp/myfirstbot-v3"
  },
  "dependencies": {
    "@types/body-parser": "^1.19.4",
    "@types/express": "^4.17.20",
    "@types/node": "^20.8.6",
    "@types/node-telegram-bot-api": "^0.61.8",
    "body-parser": "^1.20.2",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "node-telegram-bot-api": "^0.63.0",
    "typescript": "^5.2.2"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.3",
    "@types/sinon": "^10.0.20",
    "mocha": "^10.2.0",
    "nyc": "^15.1.0",
    "sinon": "^16.1.3",
    "ts-node": "^10.9.1"
  }
