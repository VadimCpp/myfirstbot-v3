  "bugs": {
    "url": "https://github.com/VadimCpp/myfirstbot-v3"
  },
  "dependencies": {
    "@types/body-parser": "^1.19.5",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.5",
    "@types/node-telegram-bot-api": "^0.64.7",
    "body-parser": "^1.20.2",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "node-telegram-bot-api": "^0.66.0",
    "typescript": "^5.6.2"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.8",
    "@types/sinon": "^17.0.3",
    "mocha": "^10.7.3",
    "nyc": "^17.1.0",
    "sinon": "^19.0.2",
    "ts-node": "^10.9.2"
  }
